# nervus2 environment variables
# Copy to .env and adjust

# Infrastructure
NATS_URL=nats://nats:4222
REDIS_URL=redis://redis:6379
POSTGRES_URL=postgresql://nervus:nervus@postgres:5432/nervus2

# AI inference (local llama.cpp)
LLAMA_URL=http://llama:8080
WHISPER_URL=http://whisper:9000

# Personal Model tuning
MODEL_UPDATER_INTERVAL=300     # seconds (default: 5 min)
INSIGHT_INTERVAL=3600          # seconds (default: 1 hour)
MAX_PROMPT_TOKENS=3072         # Jetson memory budget
MAX_RESPONSE_TOKENS=512

# Cold-start override (seconds): accelerate for testing
# PHASE1_THRESHOLD=60
# PHASE2_THRESHOLD=120

# Logging
LOG_LEVEL=INFO

# Service discovery
ARBOR_URL=http://arbor-core:8090
PERSONAL_MODEL_URL=http://personal-model:8100
